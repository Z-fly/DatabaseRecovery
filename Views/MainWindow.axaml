<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DatabaseRecovery.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1360"
        d:DesignHeight="840"
        x:Class="DatabaseRecovery.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Width="1360"
        Height="840"
        MinWidth="1120"
        MinHeight="720"
        Background="#F5F7FA"
        Title="数据库取证工具">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="主色刷" Color="#1677FF"/>
        <SolidColorBrush x:Key="浅主色刷" Color="#EAF4FF"/>
        <SolidColorBrush x:Key="正文刷" Color="#16243B"/>
        <SolidColorBrush x:Key="次要文字刷" Color="#748296"/>
        <SolidColorBrush x:Key="边框刷" Color="#E4E9F0"/>
        <SolidColorBrush x:Key="表头刷" Color="#F7F9FC"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource 边框刷}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.tool-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource 边框刷}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource 主色刷}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource 主色刷}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource 主色刷}"/>
            <Setter Property="BorderBrush" Value="#C9D9ED"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
        <Style Selector="Button.text-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource 主色刷}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource 正文刷}"/>
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource 正文刷}"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource 次要文字刷}"/>
        </Style>
        <Style Selector="TextBlock.table-head">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#516178"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.table-cell">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource 正文刷}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="48,*">
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource 边框刷}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Border Background="{StaticResource 浅主色刷}"
                            BorderBrush="#CCE4FF"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,5">
                        <TextBlock Text="数据库取证工具" Foreground="{StaticResource 正文刷}" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#20B9EE" CornerRadius="3" Padding="8,3">
                        <TextBlock Text="{Binding 软件版本}" Foreground="White" FontSize="11"/>
                    </Border>
                    <TextBlock Text="{Binding 当前数据源提示}" Classes="muted" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <Button Classes="secondary" Content="服务管理"/>
                    <Button Classes="secondary" Content="用户中心"/>
                    <Button Classes="secondary" Content="菜单"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding 显示首页}" Margin="16" RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14" Margin="0,0,0,14">
                    <Border Grid.Column="0" Classes="tool-card">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <TextBlock Text="关系型数据库" Classes="subtitle"/>
                            <TextBlock Grid.Row="1"
                                       Text="支持：MySQL, SQL文档, 阿里云高级下载文件, SQL Server, Oracle, SQLite, PostgreSQL 等"
                                       Classes="muted"
                                       Margin="0,9,0,14"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       ToolTip.Tip="支持：MySQL, SQL文档, 阿里云高级下载文件, SQL Server, Oracle, Access, SQLite, PostgreSQL, MariaDB, Realm"/>
                            <Button Grid.Row="2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Classes="text-action"
                                    Content="添加数据库"
                                    Click="打开关系型数据库_Click"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Classes="tool-card">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <TextBlock Text="非关系型数据库" Classes="subtitle"/>
                            <TextBlock Grid.Row="1"
                                       Text="支持：MongoDB, Redis, LevelDB, IndexedDB 等数据库解析"
                                       Classes="muted"
                                       Margin="0,9,0,14"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       ToolTip.Tip="支持：MongoDB, Redis, LevelDB, IndexedDB"/>
                            <Button Grid.Row="2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Classes="text-action"
                                    Content="添加数据库"
                                    Click="打开非关系型数据库_Click"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Classes="tool-card">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <TextBlock Text="日志分析" Classes="subtitle"/>
                            <TextBlock Grid.Row="1"
                                       Text="支持：MySQL binlog 日志分析 5.6 ~ 8.0"
                                       Classes="muted"
                                       Margin="0,9,0,14"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       ToolTip.Tip="支持：MySQL binlog 日志分析 5.6 ~ 8.0"/>
                            <Button Grid.Row="2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Classes="text-action"
                                    Content="打开日志分析"
                                    Click="打开日志分析_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Classes="panel" Padding="16">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14">
                            <TextBlock Text="历史记录" Classes="title" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Margin="14,0,0,0"
                                       Text="{Binding 操作提示}"
                                       Foreground="{StaticResource 主色刷}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <TextBox Width="150" Text="{Binding 筛选开始日期}" PlaceholderText="开始日期"/>
                                <TextBox Width="150" Text="{Binding 筛选结束日期}" PlaceholderText="结束日期"/>
                                <TextBox Width="220" Text="{Binding 筛选关键词}" PlaceholderText="请输入数据库名称"/>
                                <Button Classes="primary" Content="搜索" Click="搜索历史记录_Click"/>
                                <Button Classes="secondary" Content="清空" Click="清空历史筛选_Click"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="{StaticResource 表头刷}" Padding="14,10">
                            <Grid ColumnDefinitions="2*,1.15*,1.2*,1.2*,0.8*,160">
                                <TextBlock Text="记录名称" Classes="table-head"/>
                                <TextBlock Grid.Column="1" Text="数据库类型" Classes="table-head"/>
                                <TextBlock Grid.Column="2" Text="添加时间" Classes="table-head"/>
                                <TextBlock Grid.Column="3" Text="更新时间" Classes="table-head"/>
                                <TextBlock Grid.Column="4" Text="状态" Classes="table-head"/>
                                <TextBlock Grid.Column="5" Text="操作" Classes="table-head"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding 历史记录列表}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource 边框刷}" BorderThickness="0,0,0,1" Padding="14,12">
                                            <Grid ColumnDefinitions="2*,1.15*,1.2*,1.2*,0.8*,160">
                                                <TextBlock Text="{Binding 记录名称}" Classes="table-cell"/>
                                                <TextBlock Grid.Column="1" Text="{Binding 数据库类型}" Classes="table-cell"/>
                                                <TextBlock Grid.Column="2" Text="{Binding 创建时间}" Classes="table-cell"/>
                                                <TextBlock Grid.Column="3" Text="{Binding 修改时间}" Classes="table-cell"/>
                                                <TextBlock Grid.Column="4" Text="{Binding 状态}" Classes="table-cell"/>
                                                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6">
                                                    <Button Classes="text-action" Content="预览" Click="打开历史记录_Click"/>
                                                    <Button Classes="text-action" Content="更多" Click="打开数据源详情_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding 显示预处理}" Margin="16" RowDefinitions="Auto,*">
                <TextBlock Text="预处理" Classes="title"/>
                <Border Grid.Row="1" Classes="panel" Margin="0,14,0,0" Padding="22">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                        <TextBlock Text="预处理已结束" Classes="title"/>
                        <TextBlock Grid.Row="1" Text="预处理完成" Classes="muted" Margin="0,10,0,14"/>
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
                            <ProgressBar Height="10" Minimum="0" Maximum="100" Value="{Binding 处理进度}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="18" Margin="16,0,0,0">
                                <TextBlock Text="{Binding 处理进度, StringFormat={}{0}%}" Foreground="{StaticResource 主色刷}"/>
                                <TextBlock Text="{Binding 处理用时, StringFormat=耗时：{0}}" Classes="muted"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="3"
                                Background="#FAFBFD"
                                BorderBrush="{StaticResource 边框刷}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding 预处理日志列表}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding 内容}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#46566D"
                                                       Margin="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10"
                                    Margin="0,18,0,0">
                            <Button Classes="secondary" Content="返回首页" Click="返回首页_Click"/>
                            <Button Classes="primary"
                                    Content="进入预览"
                                    IsEnabled="{Binding 处理完成}"
                                    Click="进入预览_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding 显示预览}" Margin="16" RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="secondary" Content="返回首页" Click="返回首页_Click"/>
                        <TextBlock Text="{Binding 当前记录名称}" Classes="title" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding 当前源文件路径}"
                               Classes="muted"
                               Margin="18,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="数据解析"/>
                        <Button Classes="primary" Content="导出表记录" Click="导出表记录_Click"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="264,*" ColumnSpacing="14" Margin="0,14,0,0">
                    <Border Classes="panel" Padding="12">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <TextBlock Text="数据预览" Classes="title"/>
                            <TextBox Grid.Row="1" PlaceholderText="筛选数据表" Margin="0,12,0,10"/>
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding 表列表}"
                                     SelectedItem="{Binding 当前表}"
                                     SelectionChanged="预览表选择变更">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding 显示名称}"
                                                   Margin="8,7"
                                                   Foreground="{StaticResource 正文刷}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Classes="panel" Padding="14">
                        <Grid RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                <Button Classes="text-action" Content="表记录" Click="显示表记录_Click"/>
                                <Button Grid.Column="1" Classes="text-action" Content="表结构" Click="显示表结构_Click"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding 操作提示}"
                                           Classes="muted"
                                           VerticalAlignment="Center"
                                           Margin="12,0"/>
                                <ToggleSwitch Grid.Column="3"
                                              Content="详情视图"
                                              IsChecked="{Binding 是否显示详细视图}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,15,0"/>
                                <Button Grid.Column="4"
                                        Classes="secondary"
                                        Content="设置列"
                                        Click="设置列_Click"/>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid IsVisible="{Binding 显示表记录}" ColumnDefinitions="*,Auto,Auto">
                                    <Border BorderBrush="{StaticResource 边框刷}" BorderThickness="1" CornerRadius="4">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <Border Background="{StaticResource 表头刷}" Padding="10,9">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="#" Width="48" Classes="table-head"/>
                                                        <ItemsControl ItemsSource="{Binding 显示字段列表}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding 名称}"
                                                                               Width="145"
                                                                               Classes="table-head"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                                <ListBox ItemsSource="{Binding 数据行列表}"
                                                         SelectedItem="{Binding 当前选中行}"
                                                         SelectionChanged="数据行选择变更">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="10,7">
                                                                <TextBlock Text="{Binding 序号}" Width="48" Classes="table-cell"/>
                                                                <ItemsControl ItemsSource="{Binding 单元格列表}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding 值}"
                                                                                       Width="145"
                                                                                       Classes="table-cell"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                    <Border Grid.Column="1"
                                            Classes="panel"
                                            Width="300"
                                            Margin="12,0,0,0"
                                            Padding="12"
                                            IsVisible="{Binding 是否显示详细视图}">
                                        <Grid RowDefinitions="Auto,*">
                                            <TextBlock Text="记录详情" Classes="subtitle"/>
                                            <ScrollViewer Grid.Row="1" Margin="0,10,0,0">
                                                <ItemsControl ItemsSource="{Binding 选中行详情列表}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="105,*" Margin="0,6">
                                                                <TextBlock Text="{Binding 名称}" Classes="muted" FontSize="12"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding 值}"
                                                                           Classes="table-cell"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="2"
                                            Classes="panel"
                                            Width="285"
                                            Margin="12,0,0,0"
                                            Padding="12"
                                            IsVisible="{Binding 是否显示列设置}">
                                        <Grid RowDefinitions="Auto,Auto,*">
                                            <TextBlock Text="设置列" Classes="subtitle"/>
                                            <TextBox Grid.Row="1" PlaceholderText="搜索列名称" Margin="0,10"/>
                                            <ScrollViewer Grid.Row="2">
                                                <ItemsControl ItemsSource="{Binding 字段列表}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding 名称}"
                                                                      IsChecked="{Binding 是否显示}"
                                                                      Click="字段显示_Click"
                                                                      Margin="2,6"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Border IsVisible="{Binding 显示表结构}"
                                        BorderBrush="{StaticResource 边框刷}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <Grid RowDefinitions="Auto,*">
                                        <Border Background="{StaticResource 表头刷}" Padding="14,10">
                                            <Grid ColumnDefinitions="2*,1.5*,1.1*,1.4*,0.9*">
                                                <TextBlock Text="字段名称" Classes="table-head"/>
                                                <TextBlock Grid.Column="1" Text="字段类型" Classes="table-head"/>
                                                <TextBlock Grid.Column="2" Text="允许为空" Classes="table-head"/>
                                                <TextBlock Grid.Column="3" Text="默认值" Classes="table-head"/>
                                                <TextBlock Grid.Column="4" Text="主键" Classes="table-head"/>
                                            </Grid>
                                        </Border>
                                        <ScrollViewer Grid.Row="1">
                                            <ItemsControl ItemsSource="{Binding 字段列表}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource 边框刷}" BorderThickness="0,0,0,1" Padding="14,11">
                                                            <Grid ColumnDefinitions="2*,1.5*,1.1*,1.4*,0.9*">
                                                                <TextBlock Text="{Binding 名称}" Classes="table-cell"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding 类型}" Classes="table-cell"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding 允许为空}" Classes="table-cell"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding 默认值}" Classes="table-cell"/>
                                                                <TextBlock Grid.Column="4" Text="{Binding 主键}" Classes="table-cell"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid IsVisible="{Binding 显示新增弹窗}" Background="#66000000">
                <Border Width="830"
                        Height="525"
                        Classes="panel"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                            <TextBlock Text="{Binding 新增弹窗标题}" Classes="title"/>
                            <Button Grid.Column="1" Classes="text-action" Content="关闭" Click="取消新增_Click"/>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="180,*" ColumnSpacing="20">
                            <ListBox ItemsSource="{Binding 可选数据库类型列表}"
                                     SelectedItem="{Binding 当前数据库类型}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding 名称}" Margin="10,9"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Column="1" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding 当前数据库类型.名称}" Classes="title"/>
                                    <TextBlock Text="{Binding 当前数据库类型.版本, StringFormat=支持版本：{0}}"
                                               Classes="muted"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="记录名称" Classes="muted"/>
                                <TextBox Text="{Binding 新建记录名称}" PlaceholderText="请输入记录名称"/>
                                <TextBlock Text="数据来源" Classes="muted"/>
                                <StackPanel Orientation="Horizontal" Spacing="18">
                                    <RadioButton GroupName="来源" IsChecked="True" Content="文件"/>
                                    <RadioButton GroupName="来源" Content="文件夹"/>
                                </StackPanel>
                                <TextBlock Text="数据文件" Classes="muted"/>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Text="{Binding 新建源文件路径}" PlaceholderText="请选择 SQLite 数据库文件"/>
                                    <Button Grid.Column="1" Classes="secondary" Content="选择文件" Click="选择数据库文件_Click"/>
                                </Grid>
                                <TextBlock Text="保存位置" Classes="muted"/>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Text="{Binding 新建保存位置}" PlaceholderText="请选择保存位置"/>
                                    <Button Grid.Column="1" Classes="secondary" Content="选择文件夹" Click="选择保存目录_Click"/>
                                </Grid>
                                <TextBlock Text="{Binding 表单错误}" Foreground="#E74C3C"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10"
                                    Margin="0,16,0,0">
                            <Button Classes="secondary" Content="取消" Click="取消新增_Click"/>
                            <Button Classes="primary" Content="添加处理" Click="开始预处理_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding 显示数据源详情}" Background="#66000000">
                <Border Width="620"
                        Classes="panel"
                        Padding="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Text="数据源详情" Classes="title"/>
                        <Grid Grid.Row="1" ColumnDefinitions="135,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,20,0,22">
                            <TextBlock Text="记录名称" Classes="muted" Margin="0,7"/>
                            <TextBlock Grid.Column="1" Text="{Binding 当前详情记录.记录名称}" Margin="0,7"/>
                            <TextBlock Grid.Row="1" Text="数据库类型" Classes="muted" Margin="0,7"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding 当前详情记录.数据库类型}" Margin="0,7"/>
                            <TextBlock Grid.Row="2" Text="数据源 ID" Classes="muted" Margin="0,7"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding 当前详情记录.编号}" Margin="0,7"/>
                            <TextBlock Grid.Row="3" Text="创建 / 修改时间" Classes="muted" Margin="0,7"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding 当前详情记录.创建时间}" Margin="0,7"/>
                            <TextBlock Grid.Row="4" Text="源文件" Classes="muted" Margin="0,7"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding 当前详情记录.源文件}"
                                       TextWrapping="Wrap"
                                       Margin="0,7"/>
                            <TextBlock Grid.Row="5" Text="数据源目录" Classes="muted" Margin="0,7"/>
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="{Binding 当前详情记录.数据源目录}"
                                       TextWrapping="Wrap"
                                       Margin="0,7"/>
                        </Grid>
                        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                            <Button Classes="secondary" Content="取消" Click="关闭数据源详情_Click"/>
                            <Button Classes="primary" Content="确认" Click="关闭数据源详情_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
